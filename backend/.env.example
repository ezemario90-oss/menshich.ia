
# Variables de entorno para backend
###########################################
# Ejemplo de archivo .env para backend y frontend
# Completa cada variable según tu entorno real
# NOTA: Las variables que comienzan con NEXT_PUBLIC_ estarán disponibles en el frontend (cliente).
# Las demás son privadas y solo accesibles desde el backend.
###########################################

# --- Backend ---
DATABASE_URL=postgresql://usuario:clave@localhost:5432/mi_db
JWT_SECRET=mi_clave_super_segura_123
FB_APP_SECRET=fb_app_secret_987654321
ADMIN_USER=admin
ADMIN_PASS=admin123
FACEBOOK_PAGE_TOKEN=EAAG...ZCZB
FACEBOOK_VERIFY_TOKEN=verifica_fb_2026
WHATSAPP_TOKEN=EAA...ZCZB
WHATSAPP_PHONE_ID=1234567890
INSTAGRAM_ACCESS_TOKEN=IGQV...ZDZD
INSTAGRAM_USER_ID=17841400000000000
OPENAI_API_KEY=sk-abc123def456
GOOGLE_CLIENT_ID=1234567890-abcdefg.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-abcdefg123456
EMAIL_SERVER=smtp://usuario:clave@smtp.com:587
API_KEY_xxx=api_key_ejemplo_2026
STRIPE_API_KEY=sk_test_51H...abc
NODE_ENV=production
PORT=3000

# --- Frontend ---
NEXT_PUBLIC_BACKEND_URL=https://menshichia-backend.onrender.com
