model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  email        String   @unique
  password     String
  paymentStatus String  @default("active") // "active" o "expired"
  lastPayment  DateTime?
}
// Prisma schema for Step 4
// Define models: Product, Variant, Order, ChannelConfig

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  price       Float
  imageUrl    String?
  variants    Variant[]
}

model Variant {
  id        Int      @id @default(autoincrement())
  product   Product  @relation(fields: [productId], references: [id])
  productId Int
  size      String
  stock     Int
}

model Order {
  id              Int      @id @default(autoincrement())
  customerEmail   String
  total           Float
  status          String
  paymentIntentId String
  aiStyle      String   @default("amigable") // Estilos IA: amigable, formal, comercial, breve, experto, humorístico, motivador, educativo, multilingüe. Permite combinación separados por coma.
  channel         String
  createdAt       DateTime @default(now())
}

model ChannelConfig {
  id          Int      @id @default(autoincrement())
  channelName String
  config      Json
}
