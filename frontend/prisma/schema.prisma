// Prisma schema for Step 4
// Define models: Product, Variant, Order, ChannelConfig

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  price       Float
  imageUrl    String?
  variants    Variant[]
}

model Variant {
  id        Int      @id @default(autoincrement())
  product   Product  @relation(fields: [productId], references: [id])
  productId Int
  size      String
  stock     Int
}

model Order {
  id              Int      @id @default(autoincrement())
  customerEmail   String
  total           Float
  status          String
  paymentIntentId String
  channel         String
  createdAt       DateTime @default(now())
}

model ChannelConfig {
  id          Int      @id @default(autoincrement())
  channelName String
  config      Json
}
